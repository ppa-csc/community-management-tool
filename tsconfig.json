{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "nodenext",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["cypress", "node", "@testing-library/cypress"]
  },
  "include": ["cypress/**/*.ts"],
  "exclude": ["node_modules"]
}
